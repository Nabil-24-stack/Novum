# Anthropic API Key for Claude
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Supabase (for auth, persistence, publishing)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe (for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID_AUD=

# App URL (used for Stripe redirect URLs)
APP_URL=http://localhost:3000

# Billing configuration (optional — defaults shown)
BILLING_USAGE_INPUT_USD_PER_MILLION=3
BILLING_USAGE_OUTPUT_USD_PER_MILLION=15
BILLING_FREE_MONTHLY_GENERATIONS=2
BILLING_FREE_SHARED_BUDGET_USD_MICROS=1500000
BILLING_PRO_MONTHLY_BUDGET_USD_MICROS=10000000
BILLING_USAGE_WARN_PCT=80
BILLING_USAGE_CRITICAL_PCT=90
